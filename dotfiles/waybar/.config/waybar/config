{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 6,
  "modules-left": [
    "sway/workspaces",
    "sway/mode",
    "privacy",
    "sway/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "tray",
    "pulseaudio",
    "network",
    "sway/language",
    "idle_inhibitor",
    "power-profiles-daemon",
    "battery",
    "custom/power"
  ],
  "custom/power": {
    "format": "",
    "tooltip": false,
    "on-click": ""
  },
  "sway/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": []
    },
    "format-icons": {
      "focused": "",
      "default": "",
      "urgent": ""
    },
    "disable-scroll": true,
    "all-outputs": true,
    "sort-by-number": true
  },
  "sway/mode": {
    "format": "{}",
    "max-length": 50
  },
  "sway/window": {
    "format": "{title}",
    "icon": true,
    "icon-size": 18,
    "max-length": 40,
    "separate-outputs": true
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "",
      "deactivated": "󰾪"
    },
    "tooltip": true,
    "tooltip-format-activated": "Caffeine: ON",
    "tooltip-format-deactivated": "Caffeine: OFF"
  },
  "memory": {
    "interval": 5,
    "format": "{}% ",
    "max-length": 10
  },
  "cpu": {
    "interval": 5,
    "format": "{}% ",
    "max-length": 10
  },
  "custom/nvidia": {
    "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu --format=csv,nounits,noheader | sed 's/\\([0-9]\\+\\), \\([0-9]\\+\\)/\\1% 🌡️\\2°C/g'",
    "interval": 5,
    "format": "{} 󰢮"
  },
  "sway/language": {
    "format": " {short}",
    "tooltip-format": "{flag} {long}{variant}",
    "tooltip": true,
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": "",
      "power-saver": ""
    }
  },
  "battery": {
    "format": "{icon}",
    "tooltip-format": "{capacity}%",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ]
  },
  "clock": {
    "format": "{:%F | %I:%M %p}",
    "format-alt": "{:L%A, %B %d, %Y (%R)}",
    "tooltip-format": "<span>{calendar}</span>"
  },
  "network": {
    "format-wifi": " ",
    "format-ethernet": "󰈀",
    "format-disconnected": "󰖪",
    "tooltip-format-wifi": "{essid}",
    "tooltip-format-ethernet": "Wired",
    "tooltip-format-disconnected": "Offline"
  },
  "pulseaudio": {
    "format": "{icon}",
    "tooltip-format": "{volume}%",
    "format-bluetooth": "{volume}% {icon}",
    "format-muted": "0% ",
    "format-icons": {
      "headphone": "",
      "hands-free": "",
      "headset": "",
      "hdmi": "",
      "phone": "",
      "phone-muted": "",
      "portable": "",
      "car": "",
      "default": [
        "",
        " ",
        " "
      ]
    },
    "scroll-step": 0.6,
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },
  "privacy": {
    "icon-spacing": 4,
    "icon-size": 18,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-out",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "location",
        "icon-name": "location-services-active-symbolic"
      }
    ],
    "ignore-monitor": true,
    "ignore": [
      {
        "type": "audio-in",
        "name": "cava"
      },
      {
        "type": "screenshare",
        "name": "obs"
      }
    ]
  },
  "tray": {
    "icon-size": 20,
    "spacing": 20 
  }
}
